# KaamLok Backend Environment
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/kaamlok

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie
COOKIE_SAMESITE=lax

# Email (SMTP) — leave blank to log OTPs to console in dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=KaamLok <no-reply@kaamlok.in>

# CORS
CLIENT_ORIGIN=http://localhost:5173
